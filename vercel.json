{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/styles.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "redirects": [
    { "source": "/izrada-sajtova/", "destination": "/izrada-sajtova", "permanent": true },
    { "source": "/optimizacija-sajta/", "destination": "/optimizacija-sajta", "permanent": true },
    { "source": "/online-marketing/", "destination": "/online-marketing", "permanent": true },
    { "source": "/odrzavanje-sajta/", "destination": "/odrzavanje-sajta", "permanent": true },
    { "source": "/priprema-za-stampu/", "destination": "/priprema-za-stampu", "permanent": true },
    { "source": "/kontakt/", "destination": "/kontakt", "permanent": true }
  ]
}
